{
  "info": {
    "_postman_id": "b4956a57-1d3a-4edc-95f6-5d6d5f2e9f7b",
    "name": "Notifications + FCM Test",
    "description": "Postman collection to verify notification APIs and FCM push flow on deployed backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1) Register FCM Token (User)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{userToken}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token\": \"{{fcmToken}}\",\n  \"platform\": \"{{platform}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/user/notifications/token",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "user",
            "notifications",
            "token"
          ]
        }
      }
    },
    {
      "name": "2) Send Test Notification (Admin -> User)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const json = pm.response.json();",
              "if (json && json._id) {",
              "  pm.environment.set('notificationId', json._id);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"title\": \"Push Test\",\n  \"message\": \"Testing FCM from backend\",\n  \"type\": \"general\",\n  \"metadata\": {\n    \"deepLink\": \"/wallet\",\n    \"entityId\": \"test_001\"\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/admin/notifications",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "admin",
            "notifications"
          ]
        }
      }
    },
    {
      "name": "3) List User Notifications",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "if (json && Array.isArray(json.data) && json.data.length > 0) {",
              "  pm.environment.set('notificationId', json.data[0]._id);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{userToken}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/user/notifications?limit=20&page=1",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "user",
            "notifications"
          ],
          "query": [
            {
              "key": "limit",
              "value": "20"
            },
            {
              "key": "page",
              "value": "1"
            }
          ]
        }
      }
    },
    {
      "name": "4) Mark Notification Read",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{userToken}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/user/notifications/{{notificationId}}/read",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "user",
            "notifications",
            "{{notificationId}}",
            "read"
          ]
        }
      }
    },
    {
      "name": "5) Unregister FCM Token (User)",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{userToken}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token\": \"{{fcmToken}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/user/notifications/token",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "user",
            "notifications",
            "token"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://your-render-service.onrender.com"
    },
    {
      "key": "userToken",
      "value": ""
    },
    {
      "key": "adminToken",
      "value": ""
    },
    {
      "key": "userId",
      "value": ""
    },
    {
      "key": "fcmToken",
      "value": ""
    },
    {
      "key": "platform",
      "value": "android"
    },
    {
      "key": "notificationId",
      "value": ""
    }
  ]
}
